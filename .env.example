# Blogify Environment Variables

# PostgreSQL
POSTGRES_USER=blogify
POSTGRES_PASSWORD=blogify_secret_dev
POSTGRES_DB=blogify
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://blogify:blogify_secret_dev@postgres:5432/blogify

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO
MINIO_ROOT_USER=blogify_minio
MINIO_ROOT_PASSWORD=blogify_minio_secret
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=blogify-media
MINIO_USE_SSL=false

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
